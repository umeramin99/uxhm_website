---
/* src/components/common/JsonLd.astro
 *
 * Renders JSON-LD structured data for SEO. Renders a LocalBusiness object on every
 * page (via Layout.astro) and an Article object on blog posts when post props are passed.
 *
 * Schema.org reference: https://schema.org/LocalBusiness, https://schema.org/Article
 */

import { I18N } from 'astrowind:config';

export interface BlogPostMeta {
  title: string;
  description?: string;
  publishDate?: Date;
  updateDate?: Date;
  image?: string;
  author?: string;
  category?: { title: string } | string;
  slug: string;
}

export interface Props {
  post?: BlogPostMeta;
}

const { post } = Astro.props as Props;
const SITE_URL = 'https://uxhm.co.uk';
const SITE_NAME = 'UXHM';
const LOGO_URL = SITE_URL + '/_astro/default.D6hLHdmE_1949Vb.jpg';

const localBusiness = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: SITE_NAME,
  description: 'Websites, branding and SEO for UK small businesses, tradespeople and salons.',
  url: SITE_URL,
  logo: LOGO_URL,
  image: LOGO_URL,
  email: 'hello@uxhm.co.uk',
  priceRange: '££',
  areaServed: { '@type': 'Country', name: 'United Kingdom' },
  address: { '@type': 'PostalAddress', addressCountry: 'GB' },
  sameAs: [
    'https://www.linkedin.com/company/uxhm/',
    'https://uk.trustpilot.com/review/uxhm.co.uk',
  ],
};

const articleLd = post && {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.title,
  description: post.description,
  image: post.image ? (post.image.startsWith('http') ? post.image : SITE_URL + post.image) : LOGO_URL,
  datePublished: post.publishDate?.toISOString(),
  dateModified: (post.updateDate ?? post.publishDate)?.toISOString(),
  author: { '@type': 'Person', name: post.author ?? 'Hira Saeed' },
  publisher: {
    '@type': 'Organization',
    name: SITE_NAME,
    logo: { '@type': 'ImageObject', url: LOGO_URL },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': SITE_URL + '/' + post.slug,
  },
  inLanguage: I18N?.language ?? 'en',
};
---

<script type="application/ld+json" set:html={JSON.stringify(localBusiness)} />
{articleLd && <script type="application/ld+json" set:html={JSON.stringify(articleLd)} />}
