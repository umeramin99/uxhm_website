---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'UXHM | UK Small Business Digital Specialists',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <Hero
    tagline="UK Small Business Specialists"
    actions={[
      {
        variant: 'primary',
        text: 'Get Your Free Quote',
        href: '/contact',
        icon: 'tabler:mail',
      },
      { text: 'View Our Packages', href: '/services' },
    ]}
    image={{ src: '~/assets/images/hero-image.jpg', alt: 'UXHM Digital Dashboard' }}
  >
    <Fragment slot="title">
      Stop Losing Customers. <span class="text-accent highlight">Start Winning Online.</span>
    </Fragment>

    <Fragment slot="subtitle">
      We don't just build websites. From <span class="font-semibold">Logos</span> and <span class="font-semibold">Mobile Apps</span> to <span class="font-semibold">SEO</span> and <span class="font-semibold">Social Media</span>, UXHM is the only digital partner your business needs.
    </Fragment>
  </Hero>

  <Features
    id="features"
    tagline="The All-In-One Solution"
    title="Why hire 5 freelancers when you can hire 1 partner?"
    subtitle="Everything you need to launch and grow, all under one roof."
    items={[
      {
        title: 'Websites & Apps',
        description:
          'Stunning, fast, mobile-first sites and bespoke apps that work perfectly on every device.',
        icon: 'tabler:device-laptop',
      },
      {
        title: 'Branding & Graphics',
        description:
           'Professional logos, flyers, and visual assets that establish credibility from day one.',
        icon: 'tabler:palette',
      },
      {
        title: 'Growth & SEO',
        description:
           'Rank higher on Google and turn visitors into paying customers.',
        icon: 'tabler:chart-bar',
      },
      {
        title: 'Monthly Care',
        description:
          'Maintenance and social media management, starting at just £50/mo.',
        icon: 'tabler:refresh',
      },
    ]}
  />

  <Content
    isReversed
    items={[
      {
        title: 'The Problem',
        description:
           'You\'re an expert at what you do, but your website looks outdated and your social media is silent. You know you\'re losing business to competitors, but you don\'t have the time or know-how to change it.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1525547719571-a2d4ac8945e2?ixlib=rb-4.0.3&auto=format&fit=crop&w=2344&q=80',
      alt: 'Business Owner Struggling',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Is your online presence letting you down?
      </h3>
    </Fragment>
  </Content>

  <Content
    items={[
      {
        title: 'The UXHM Solution',
        description:
           'We specialise in one thing: helping UK small businesses succeed online. Whether you need a simple "Digital Foundation" site or a fully custom "Interactive MVP" app, we handle the technology so you can focus on running your business.',
      },
    ]}
    image={{
      src: '~/assets/images/brand-book.png',
      alt: 'UXHM',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        We turn your expertise into a digital engine.
      </h3>
    </Fragment>
  </Content>

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Get Your Free Quote',
        href: '/contact',
        icon: 'tabler:mail',
      },
    ]}
  >
     <Fragment slot="title">Ready to take your business online?</Fragment>

    <Fragment slot="subtitle">
       Your consultation is free, with no obligation. Let's discuss how we can help.
    </Fragment>
  </CallToAction>
</Layout>