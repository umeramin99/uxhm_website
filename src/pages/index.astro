---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'UXHM | Websites That Book the Job for UK Small Businesses',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <Hero
    tagline="websites for UK small businesses"
    actions={[
      {
        variant: 'primary',
        text: 'Get a Free Quote',
        href: '/contact',
        icon: 'tabler:mail',
      },
      { text: 'See Our Packages', href: '#industries' },
    ]}
    image={{
      src: '~/assets/images/hero-image.jpg',
      alt: 'UK small business owner reviewing their new website',
    }}
  >
    <Fragment slot="title">
      A Website That <span class="text-accent highlight">Books the Job for You.</span>
    </Fragment>

    <Fragment slot="subtitle">
      Fast, fixed-price websites for UK small businesses. Live in 7 working days. <strong>From £249.</strong>
      No tech jargon. No timeline nightmares.
    </Fragment>
  </Hero>

  <Features
    id="industries"
    tagline="Pick Your Industry"
    title="Built For The Businesses We Serve Best"
    subtitle="See exactly what you get and how much it costs. Every package goes live in 7 working days."
    items={[
      {
        title: 'Tradies',
        description:
          'Plumbers, electricians, builders & heating engineers. Mobile-first sites that fill your diary, not your inbox. From £249.',
        icon: 'tabler:tool',
      },
      {
        title: 'Salons',
        description:
          'Hair, nail & beauty salons. Insta-grade design with Fresha/Treatwell booking front and centre. From £249.',
        icon: 'tabler:scissors',
      },
      {
        title: 'Everyone Else',
        description:
          'Restaurants, tutors, consultants, retailers — same chat-first, fixed-price approach. Get in touch for a free quote.',
        icon: 'tabler:building-store',
      },
    ]}
  />

  <Content
    isReversed
    items={[
      {
        title: 'Mobile-First, Tap-to-Call',
        description:
          'Most of your customers find you on a phone. Every page on your site lets them tap once to ring you, book you, or message you.',
      },
      {
        title: 'Local SEO Built In',
        description:
          'Ranked for "[your business] [your town]" so locals find you before your competitors.',
      },
      {
        title: 'Live in 7 Working Days',
        description:
          'Fixed price. Fixed timeline. Live while you\'re still finishing the work you\'ve already booked.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1581094794329-c8112a89af12?ixlib=rb-4.0.3&auto=format&fit=crop&w=2344&q=80',
      alt: 'UK tradesperson with tablet checking website',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        For Plumbers, Sparks & Builders
      </h3>
      <p class="text-muted">
        Sites that fill your diary, not your inbox. Tradie Starter from <strong>£249</strong>, Growth from
        <strong>£499</strong>, Pro for multi-van firms from <strong>£899</strong>.
      </p>
    </Fragment>
  </Content>

  <div class="text-center -mt-8 mb-12">
    <a href="/for-tradies" class="btn btn-primary">See the Tradie Packages →</a>
  </div>

  <Content
    items={[
      {
        title: 'Booking Front and Centre',
        description:
          'Direct integration with Fresha, Treatwell, Booksy or your booking system. One tap from homepage to booked.',
      },
      {
        title: 'Built for Insta Scrollers',
        description:
          'Most of your customers find you on Insta. Your site needs to look as good as your work does on the grid.',
      },
      {
        title: 'Live in 7 Working Days',
        description: 'Fixed price. Fixed timeline. Live before your next quiet week.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1560066984-138dadb4c035?ixlib=rb-4.0.3&auto=format&fit=crop&w=2344&q=80',
      alt: 'Modern UK hair salon interior',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        For Hair, Nail & Beauty Salons
      </h3>
      <p class="text-muted">
        Sites that turn Insta scrollers into bookings. Salon Starter from <strong>£249</strong>, Growth from
        <strong>£499</strong>, Pro for multi-location salons from <strong>£899</strong>.
      </p>
    </Fragment>
  </Content>

  <div class="text-center -mt-8 mb-12">
    <a href="/for-salons" class="btn btn-primary">See the Salon Packages →</a>
  </div>

  <Features
    tagline="What You Get"
    title="Everything You Need to Get More Customers"
    subtitle="From domain to done. We handle it all."
    items={[
      {
        title: 'New Websites',
        description:
          'Clean, fast, mobile-first sites that make people trust you. Built for leads, not vanity.',
        icon: 'tabler:device-laptop',
      },
      {
        title: 'Google Business Optimisation',
        description:
          'Show up when locals search. We claim, optimise, and connect it all so you get the calls that matter.',
        icon: 'tabler:map-pin',
      },
      {
        title: 'Lead Capture',
        description:
          'Contact forms, click-to-call, quote requests. Make it easy for customers to say yes.',
        icon: 'tabler:phone-call',
      },
      {
        title: 'Ongoing Care',
        description:
          "Hosting, updates, tweaks — covered. You don't touch a thing. Ever. From £20/mo.",
        icon: 'tabler:refresh',
      },
    ]}
  />

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Get a Free Quote',
        href: '/contact',
        icon: 'tabler:mail',
      },
    ]}
  >
    <Fragment slot="title">
      Ready to Stop Losing Customers to <span class="text-accent">Worse Businesses with Better Websites?</span>
    </Fragment>

    <Fragment slot="subtitle">
      Reply with your business name and we'll send you a fixed-price quote within 24 hours. No phone calls
      unless you want one.
    </Fragment>
  </CallToAction>
</Layout>
