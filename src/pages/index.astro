---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'UXHM | Websites for Plumbers, Electricians & Builders',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <Hero
    tagline="websites for tradies"
    actions={[
      {
        variant: 'primary',
        text: 'Get Your Free Quote',
        href: '/contact',
        icon: 'tabler:mail',
      },
      { text: 'See Our Work', href: '#portfolio' },
    ]}
    image={{ src: '~/assets/images/hero-image.jpg', alt: 'Professional tradesperson with tablet' }}
  >
    <Fragment slot="title">
      Your Tools Get You to the Job. <span class="text-accent highlight">Your Website Gets You the Call.</span>
    </Fragment>

    <Fragment slot="subtitle">
      Professional websites for <span class="font-semibold">plumbers</span>, <span class="font-semibold">electricians</span>, <span class="font-semibold">builders</span> & heating engineers. We build them. You run your business. That's the deal.
    </Fragment>
  </Hero>

  <Features
    id="features"
    tagline="Why Tradies Choose Us"
    title="You Already Work 60 Hours. We'll Handle the Website."
    subtitle="No tech jargon. No timeline nightmares. Just a website that works as hard as you do."
    items={[
      {
        title: 'We Speak Your Language',
        description:
          'No "synergy" nonsense. We know what a boiler is, what a spark does, and why your van matters more than a server rack. You explain the job — we build what sells.',
        icon: 'tabler:tool',
      },
      {
        title: 'Fast Turnaround',
        description:
          'Live in days, not months. Your site goes live while you\'re still finishing the jobs you\'ve already booked. No endless revisions.',
        icon: 'tabler:clock',
      },
      {
        title: 'Beat the Nephew-Sites',
        description:
          'Your competitor\'s nephew made their site. It looks like PowerPoint 2007. Your site will look premium — because you are.',
        icon: 'tabler:trophy',
      },
    ]}
  />

  <Content
    isReversed
    id="portfolio"
    items={[
      {
        title: 'What We Build for Trades',
        description:
          'We don\'t do generic "beautiful websites." We build lead-generating machines that make people trust you before they even call.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1581094794329-c8112a89af12?ixlib=rb-4.0.3&auto=format&fit=crop&w=2344&q=80',
      alt: 'Tradesperson at work',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        New Websites That Fill Your Diary
      </h3>
    </Fragment>
  </Content>

  <Features
    tagline="What You Get"
    title="Everything You Need to Get More Customers"
    subtitle="From domain to done. We handle it all."
    items={[
      {
        title: 'New Websites',
        description:
          'Clean, fast, mobile-first sites that make people trust you. Built for leads, not vanity.',
        icon: 'tabler:device-laptop',
      },
      {
        title: 'Google Business Optimisation',
        description:
          'Show up when locals search. We claim, optimise, and connect it all so you get the calls that matter.',
        icon: 'tabler:map-pin',
      },
      {
        title: 'Lead Capture',
        description:
          'Contact forms, click-to-call, quote requests. Make it easy for customers to say yes.',
        icon: 'tabler:phone-call',
      },
      {
        title: 'Ongoing Care',
        description:
          'Hosting, updates, tweaks — covered. You don\'t touch a thing. Ever. From £50/mo.',
        icon: 'tabler:refresh',
      },
    ]}
  />

  <Content
    items={[
      {
        title: 'No Hidden Costs',
        description:
          'One price. No surprises. We tell you what it costs upfront and we stick to it. That\'s the deal.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1558618666-fcd25c85cd64?ixlib=rb-4.0.3&auto=format&fit=crop&w=2344&q=80',
      alt: 'Clear pricing',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Straight Talking. Straight Pricing.
      </h3>
    </Fragment>
  </Content>

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Get Your Free Quote',
        href: '/contact',
        icon: 'tabler:mail',
      },
    ]}
  >
    <Fragment slot="title">
      Ready to Stop Losing Jobs to <span class="text-accent">Worse Tradespeople with Better Websites?</span>
    </Fragment>

    <Fragment slot="subtitle">
      No call centre. Just a conversation. We'll get back to you in an hour. Probably less.
    </Fragment>
  </CallToAction>
</Layout>
