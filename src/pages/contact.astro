---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import ContactUs from '~/components/widgets/Contact.astro';
import Features2 from '~/components/widgets/Features2.astro';

const metadata = {
  title: 'Contact UXHM | Start Your Project',
  description: 'Get a free, no-obligation quote for your website, branding, or app. We reply within one business day.',
};
---

<Layout metadata={metadata}>
  <HeroText tagline="Contact" title="Let's Build Your Vision." />

  <ContactUs
    id="form"
    title="Get in Touch"
    action="/api/contact"
    inputs={[
      {
        type: 'text',
        name: 'name',
        label: 'Full Name',
        required: true,
      },
      {
        type: 'email',
        name: 'email',
        label: 'Email Address',
        required: true,
      },
      {
        type: 'select',
        name: 'service',
        label: 'Service of Interest',
        placeholder: 'Select a service',
        options: [
          { value: 'Website Design & Development', label: 'Website Design & Development' },
          { value: 'Mobile App Development', label: 'Mobile App Development' },
          { value: 'Branding & Logo Design', label: 'Branding & Logo Design' },
          { value: 'SEO & Growth Marketing', label: 'SEO & Growth Marketing' },
          { value: 'Monthly Maintenance Plan', label: 'Monthly Maintenance Plan' },
          { value: 'Social Media Management', label: 'Social Media Management' },
          { value: 'Other', label: 'Other' },
        ],
      },
    ]}
    textarea={{
      label: 'Tell Us More',
    }}
    disclaimer={{
      label:
        'By submitting this form, you agree to the collection of your personal information in accordance with our Privacy Policy.',
    }}
    description="We respect your privacy. See our <a href='/privacy'>Privacy Policy</a>."
  >
    <Fragment slot="subtitle">
      Share a few details below and we'll be in touch within one business day to arrange a free, no-obligation consultation.
      <br /><br />
      Prefer email? Reach us directly at <a href="mailto:hello@uxhm.co.uk" class="underline text-primary">hello@uxhm.co.uk</a>
    </Fragment>
  </ContactUs>

  <Features2
    title="We are here to help!"
    items={[
      {
        title: 'Email',
        description: 'hello@uxhm.co.uk',
        icon: 'tabler:mail',
      },
    ]}
  />
</Layout>