---
import Layout from '~/layouts/Layout.astro';
import Header from '~/components/widgets/Header.astro';
import Footer from '~/components/widgets/Footer.astro';
import { headerData, footerData } from '~/navigation';

import type { MetaData } from '~/types';

export interface Props {
  metadata?: MetaData;
}

const { metadata } = Astro.props;
const currentPath = Astro.url.pathname;
const isContactPage = currentPath === '/contact' || currentPath === '/contact/';
---

<Layout metadata={metadata}>
  <slot name="header">
    <Header {...headerData} isSticky showToggleTheme />
  </slot>
  <main>
    <slot />
  </main>
  <slot name="footer">
    <Footer {...footerData} />
  </slot>

  {!isContactPage && (
    <a
      id="floating-cta"
      href="/contact"
      class="fixed bottom-6 right-6 z-50 inline-flex items-center gap-2 px-5 py-3 rounded-full
             bg-primary text-white font-semibold text-sm
             shadow-lg hover:shadow-xl
             transition-all duration-300 ease-in-out"
      style="opacity:0; transform:translateY(1rem); -webkit-transform:translateY(1rem);"
      aria-label="Get a free quote"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
        stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
      </svg>
      <span>Get a Quote</span>
    </a>
  )}

  <script is:inline>
    (function() {
      var btn = document.getElementById('floating-cta');
      if (!btn) return;

      var shown = false;
      var hiddenByFooter = false;

      function show() {
        if (shown) return;
        shown = true;
        btn.style.opacity = '1';
        btn.style.transform = 'translateY(0)';
        btn.style.webkitTransform = 'translateY(0)';
      }

      function onScroll() {
        if (window.pageYOffset > 400) show();
      }

      // Hide when footer is in view
      var footer = document.querySelector('footer');
      if (footer && window.IntersectionObserver) {
        var obs = new IntersectionObserver(function(entries) {
          if (entries[0].isIntersecting) {
            btn.style.opacity = '0';
            btn.style.pointerEvents = 'none';
            hiddenByFooter = true;
          } else if (shown) {
            btn.style.opacity = '1';
            btn.style.pointerEvents = 'auto';
            hiddenByFooter = false;
          }
        }, { threshold: 0.1 });
        obs.observe(footer);
      }

      // Hover scale
      btn.addEventListener('mouseenter', function() {
        btn.style.transform = 'translateY(0) scale(1.05)';
        btn.style.webkitTransform = 'translateY(0) scale(1.05)';
      });
      btn.addEventListener('mouseleave', function() {
        btn.style.transform = 'translateY(0) scale(1)';
        btn.style.webkitTransform = 'translateY(0) scale(1)';
      });

      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
    })();
  </script>
</Layout>
