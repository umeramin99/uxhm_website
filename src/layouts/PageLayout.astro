---
import Layout from '~/layouts/Layout.astro';
import Header from '~/components/widgets/Header.astro';
import Footer from '~/components/widgets/Footer.astro';
import { headerData, footerData } from '~/navigation';

import type { MetaData } from '~/types';

export interface Props {
  metadata?: MetaData;
}

const { metadata } = Astro.props;
const currentPath = Astro.url.pathname;
const isContactPage = currentPath === '/contact' || currentPath === '/contact/';
---

<Layout metadata={metadata}>
  <slot name="header">
    <Header {...headerData} isSticky showToggleTheme />
  </slot>
  <main>
    <slot />
  </main>
  <slot name="footer">
    <Footer {...footerData} />
  </slot>

  {!isContactPage && (
    <a
      id="floating-cta"
      href="/contact"
      aria-label="Get a free quote"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
        stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
      </svg>
      <span>Get a Quote</span>
    </a>
  )}

  <style is:global>
    #floating-cta {
      position: fixed;
      bottom: 1.5rem;
      right: 1.5rem;
      z-index: 50;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.75rem 1.25rem;
      border-radius: 9999px;
      background-color: var(--aw-color-primary, #3b82f6);
      color: #ffffff;
      font-weight: 600;
      font-size: 0.875rem;
      text-decoration: none;
      box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1), 0 4px 6px -4px rgba(0,0,0,0.1);
      opacity: 0;
      -webkit-transform: translateY(1rem);
      transform: translateY(1rem);
      -webkit-transition: opacity 0.4s ease, transform 0.4s ease, box-shadow 0.3s ease;
      transition: opacity 0.4s ease, transform 0.4s ease, box-shadow 0.3s ease;
    }
    #floating-cta.show {
      opacity: 1;
      -webkit-transform: translateY(0);
      transform: translateY(0);
    }
    #floating-cta:hover {
      box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1), 0 8px 10px -6px rgba(0,0,0,0.1);
      -webkit-transform: translateY(0) scale(1.05);
      transform: translateY(0) scale(1.05);
    }
  </style>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
      var cta = document.getElementById('floating-cta');
      if (cta) {
        var scrollHandler = function() {
          if ((window.pageYOffset || document.documentElement.scrollTop) > 400) {
            cta.className = cta.className.indexOf('show') === -1 ? cta.className + ' show' : cta.className;
            window.removeEventListener('scroll', scrollHandler);
          }
        };
        window.addEventListener('scroll', scrollHandler);
        scrollHandler();
      }

      // Nuclear option for hash scrolling
      function handleHashScroll() {
        if (window.location.hash) {
          var id = window.location.hash.substring(1);
          var el = document.getElementById(id);
          if (el) {
            // console.log('Scrolling to:', id);
            // 1. Force auto scroll behavior on everything
            document.documentElement.style.scrollBehavior = 'auto';
            document.body.style.scrollBehavior = 'auto';
            
            // 2. Try scrollIntoView
            el.scrollIntoView({ behavior: 'auto', block: 'start' });
            
            // 3. Try window.scrollTo as backup
            var rect = el.getBoundingClientRect();
            var scrollTop = window.pageYOffset || document.documentElement.scrollTop;
            window.scrollTo({
              top: rect.top + scrollTop - 70, // Adjust for header approx
              behavior: 'auto'
            });

            // 4. Restore smooth scroll after a delay
            setTimeout(function() {
               document.documentElement.style.scrollBehavior = '';
               document.body.style.scrollBehavior = '';
            }, 500);
          } else {
            // console.warn('Element not found:', id);
          }
        }
      }

      // Run on every possible event
      window.addEventListener('load', handleHashScroll);
      window.addEventListener('pageshow', handleHashScroll);
      window.addEventListener('hashchange', handleHashScroll);
      document.addEventListener('astro:page-load', handleHashScroll);
      document.addEventListener('astro:after-swap', handleHashScroll);
      
      // And polling for safety
      var attempts = 0;
      var interval = setInterval(function() {
        if (window.location.hash) {
          handleHashScroll();
          attempts++;
          if (attempts > 20) clearInterval(interval); // Stop after 2 seconds
        }
      }, 100);
      
      handleHashScroll(); // Run immediately
    });
  </script>
</Layout>
