/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://challenges.cloudflare.com https://*.cloudflare.com https://www.googletagmanager.com https://*.trustpilot.com https://www.google.com https://maps.googleapis.com; style-src 'self' 'unsafe-inline' https://*.trustpilot.com; img-src 'self' data: https:; connect-src 'self' https://challenges.cloudflare.com https://*.cloudflare.com https://www.google-analytics.com https://*.trustpilot.com; frame-src https://challenges.cloudflare.com https://*.cloudflare.com https://*.trustpilot.com https://www.google.com; child-src https://challenges.cloudflare.com https://*.cloudflare.com https://*.trustpilot.com; font-src 'self' data: https://*.trustpilot.com; base-uri 'self'; form-action 'self'

/_astro/*
  Cache-Control: public, max-age=31536000, immutable
